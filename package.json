{
  "name": "condopay",
  "version": "2.0.0",
  "private": true,
  "description": "CondoPay v2 — Tier 1 (building together)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "npm run db:migrate -w @condopay/api",
    "db:seed": "npm run db:seed -w @condopay/api",
    "dev:api": "npm run dev -w @condopay/api",
    "dev:web": "npm run dev -w @condopay/web"
  }
}
